{
  "name": "ratel-ds",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tokens": "node scripts/build-tokens.js",
    "css":    "npx tailwindcss -i assets/tailwind.css -o assets/tailwind.out.css --watch",
